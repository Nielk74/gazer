{
  "name": "gazer",
  "version": "0.1.0",
  "description": "Professional desktop service monitoring dashboard",
  "author": "Gazer",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "files": [
    "assets/",
    "dist/",
    "dist-electron/"
  ],
  "scripts": {
    "build": "node build.mjs && electron-builder",
    "build:unpacked": "node build.mjs && electron-builder --dir",
    "build:app": "node build.mjs",
    "dev": "node build.mjs && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.2",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.gazer.desktop",
    "productName": "Gazer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "engines": {
    "node": ">=22.5"
  },
  "keywords": [
    "monitoring",
    "services",
    "dashboard",
    "electron",
    "operations"
  ],
  "license": "MIT"
}
